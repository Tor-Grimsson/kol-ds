{
  "name": "@kolkrabbi/kol-foundry",
  "version": "0.4.2",
  "private": false,
  "description": "KOL foundry component set — the type-specimen apparatus: typeface hero, variable-font axis playground, parsed-metric glyph inspector, character-set browser, font-preview, and the typeface-catalog grid. Every component renders, inspects, or manipulates a live font. Typeface data is consumer-injected. Sits above @kolkrabbi/kol-{theme,icons,component}.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "dependencies": {
    "@kolkrabbi/kol-component": "workspace:*",
    "@kolkrabbi/kol-icons": "workspace:*",
    "@kolkrabbi/kol-theme": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "framer-motion": "^12.0.0",
    "opentype.js": "^1.3.4"
  },
  "peerDependenciesMeta": {
    "opentype.js": {
      "optional": true
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "kol",
    "kolkrabbi",
    "design-system",
    "foundry",
    "typeface",
    "specimen",
    "type"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tor-Grimsson/kol-ds.git",
    "directory": "packages/foundry"
  },
