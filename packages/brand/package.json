{
  "name": "@kolkrabbi/kol-brand",
  "version": "0.1.0",
  "description": "Kolkrabbi's brand kit — the studio's brand manifest (identity, color ramps, type, presence) conforming to the @kolkrabbi/kol-brand-template schema, plus the brand SVG assets (logos, wordmark, favicons) under ./svg with an <Asset> loader (the Icon-loader pattern). Manifest is data-only; the loader needs React (optional peer).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./svg": "./src/svg/AssetLoader.jsx",
    "./svg/*": "./src/svg/*"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "kol",
    "kolkrabbi",
    "brand",
    "brand-kit",
    "manifest"
  ],
  "dependencies": {
    "@kolkrabbi/kol-brand-template": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tor-Grimsson/kol-ds.git",
    "directory": "packages/brand"
  },
  "publishConfig": {
    "access": "public"
  }
}
