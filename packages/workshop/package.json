{
  "name": "@kolkrabbi/kol-workshop",
  "version": "0.1.3",
  "private": false,
  "description": "KOL workshop/docs system — a handrolled markdown engine, search, tag system (incl. a d3 tag graph), docs viewer, and docs shell. Sits above @kolkrabbi/kol-{theme,icons,component,framework}; content is consumer-injected (the package never globs docs).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./engine": "./src/engine/index.js"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "@kolkrabbi/kol-brand": "workspace:^",
    "@kolkrabbi/kol-component": "workspace:*",
    "@kolkrabbi/kol-icons": "workspace:*",
    "@kolkrabbi/kol-framework": "workspace:*",
    "@kolkrabbi/kol-theme": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "react-router-dom": "^6.0.0 || ^7.0.0"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "kol",
    "kolkrabbi",
    "design-system",
    "docs",
    "markdown",
    "workshop"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tor-Grimsson/kol-ds.git",
    "directory": "packages/workshop"
  },
  "publishConfig": {
    "access": "public"
  }
}
