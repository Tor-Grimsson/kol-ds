{
  "name": "@kolkrabbi/kol-theme",
  "version": "0.1.0",
  "description": "KOL (Kolkrabbi) design-system tokens + base CSS — brand-neutral. The canonical token/cascade layer every other KOL package and consumer builds on.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
